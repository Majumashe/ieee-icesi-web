---
/**
 * ICON COLLAGE — IEEE ICESI
 * Collage de los 4 íconos emblemáticos de ICESI (torre, madroño, oso, arco).
 * Los colores derivan solos, suavemente, por la paleta de marca.
 * Versión autónoma (CSS puro, no depende de Tailwind).
 *
 * Requiere las imágenes en public/iconos/*.png
 *   reloj.png · madrono.png · oso.png · puerta.png
 *
 * Uso:
 *   import IconCollage from "../components/IconCollage.astro";
 *   <IconCollage />
 *
 * By: Majumashe - WebMaster 2026
 */
const tiles = [
  { src: "/iconos/reloj.png", alt: "Torre del reloj", frac: 0, bg: "#005da4", t: "rotate(-2deg) translateY(-14px)" },
  { src: "/iconos/madrono.png", alt: "Madroño", frac: 0.28, bg: "#01a499", t: "rotate(1.6deg) translateY(10px)" },
  { src: "/iconos/oso.png", alt: "Oso", frac: 0.55, bg: "#0118ab", t: "rotate(1.4deg) translateY(-6px)" },
  { src: "/iconos/puerta.png", alt: "Arco", frac: 0.78, bg: "#028473", t: "rotate(-1.6deg) translateY(16px)" },
];
---

<div class="ic-grid" data-icon-collage>
  {
    tiles.map((tile) => (
      <div style={`transform:${tile.t}`}>
        <div
          class="ic-tile"
          data-tile
          data-frac={tile.frac}
          style={`background:${tile.bg}`}
        >
          <img
            class="ic-icon"
            src={tile.src}
            alt={tile.alt}
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    ))
  }
</div>

<style>
  .ic-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 26px;
    width: 100%;
    max-width: 540px;
  }
  .ic-tile {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 26px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 17%;
    box-shadow: 0 22px 46px -20px rgba(0, 0, 0, 0.8);
    transition:
      transform 0.35s cubic-bezier(0.2, 0.7, 0.2, 1),
      box-shadow 0.35s;
  }
  .ic-tile:hover {
    transform: scale(1.045) translateY(-4px);
    box-shadow: 0 30px 60px -22px rgba(0, 0, 0, 0.9);
  }
  .ic-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    filter: drop-shadow(0 5px 12px rgba(0, 0, 0, 0.3));
  }
</style>

<script>
  const root = document.querySelector("[data-icon-collage]");
  if (root) {
    // Paleta de marca para la deriva de color
    const palette = [
      "#0118ab",
      "#043990",
      "#005da4",
      "#00629b",
      "#028473",
      "#01a499",
    ];

    const tiles = [...root.querySelectorAll<HTMLElement>("[data-tile]")];
    const fracs = tiles.map((el) => parseFloat(el.dataset.frac || "0"));
    let last = performance.now();
    const speed = 0.05; // deriva suave

    const hex = (h: string) => [
      parseInt(h.slice(1, 3), 16),
      parseInt(h.slice(3, 5), 16),
      parseInt(h.slice(5, 7), 16),
    ];

    const sample = (frac: number) => {
      const n = palette.length;
      const p = (((frac % 1) + 1) % 1) * n;
      const i = Math.floor(p);
      const f = p - i;
      const a = hex(palette[i]);
      const b = hex(palette[(i + 1) % n]);
      return `rgb(${Math.round(a[0] + (b[0] - a[0]) * f)},${Math.round(
        a[1] + (b[1] - a[1]) * f,
      )},${Math.round(a[2] + (b[2] - a[2]) * f)})`;
    };

    const paint = () => {
      tiles.forEach((el, i) => {
        el.style.background = sample(fracs[i]);
      });
    };

    // Respeta a quien pide menos movimiento
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (reduceMotion) {
      paint();
    } else {
      const loop = (now: number) => {
        const dt = (now - last) / 1000;
        last = now;
        tiles.forEach((_, i) => {
          fracs[i] += dt * speed;
        });
        paint();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
  }
</script>