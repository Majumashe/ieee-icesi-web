---
//Section title component
interface Props {
  title: string;
  centered?: boolean;
}

const { title, centered = true } = Astro.props;
---

<div class:list={["mb-8", centered && "text-center"]}>
  <h2 class="text-2xl pb-1 font-bold">
    {title}
  </h2>
  <div class:list={["h-1 w-80 bg-ieee-blue rounded-full", centered && "mx-auto"]}></div>
</div>
