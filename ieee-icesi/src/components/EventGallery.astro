---
/**
 * EVENT GALLERY — IEEE ICESI
 * Galería de fotos para eventos pasados con CARGA AUTOMÁTICA.
 * Encuentra las fotos por el slug del evento y muestra cuadrícula + lightbox.
 *
 * ─────────────────────────────────────────────────────────────
 * CÓMO AGREGAR FOTOS A UN EVENTO:
 *   Crea la carpeta:  src/assets/events/[slug-del-evento]/
 *   (ej. src/assets/events/rnr-bucaramanga/)
 *   Suelta ahí las fotos (.jpg .jpeg .png .webp). Aparecen solas,
 *   ordenadas por nombre de archivo. No hay que tocar events.ts.
 * ─────────────────────────────────────────────────────────────
 *
 * Props:
 *   slug  → el slug del evento (para encontrar su carpeta)
 *   title → nombre del evento (para el alt de las fotos)
 *
 * By: Majumashe - WebMaster 2026
 */

import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  slug: string;
  title?: string;
}

const { slug, title = "Evento" } = Astro.props;

// Carga TODAS las fotos de TODOS los eventos (glob estático), luego filtramos.
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/events/**/*.{jpg,jpeg,png,webp}",
  { eager: true },
);

// Filtra solo las fotos cuya ruta incluye /[slug]/ y ordénalas por nombre.
const photos = Object.entries(allImages)
  .filter(([path]) => path.includes(`/events/${slug}/`))
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);
---

{
  photos.length > 0 && (
    <section class="gallery">
      <h2 class="gallery-title">Galería</h2>
      <div class="gallery-grid">
        {photos.map((photo, i) => (
          <button class="gallery-thumb" data-gallery-item data-src={photo.src} aria-label={`Ver foto ${i + 1}`}>
            <Image src={photo} alt={`${title} — foto ${i + 1}`} width={300} loading="lazy" decoding="async" />
          </button>
        ))}
      </div>

      {/* Lightbox */}
      <div class="lightbox" data-lightbox hidden>
        <button class="lightbox-close" data-lightbox-close aria-label="Cerrar">×</button>
        <img data-lightbox-img src="" alt="" />
      </div>
    </section>
  )
}

<style>
  .gallery {
    margin-top: 2.5rem;
  }
  .gallery-title {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ieee-blue);
    font-weight: 600;
    margin-bottom: 14px;
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 10px;
  }
  .gallery-thumb {
    aspect-ratio: 1;
    border: none;
    padding: 0;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    background: color-mix(in srgb, var(--hero-text) 6%, transparent);
  }
  .gallery-thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .gallery-thumb:hover :global(img) {
    transform: scale(1.06);
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.9);
    padding: 40px;
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
  }
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 28px;
    background: none;
    border: none;
    color: white;
    font-size: 40px;
    line-height: 1;
    cursor: pointer;
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-thumb:hover :global(img) {
      transform: none;
    }
  }
</style>

<script>
  const lightbox = document.querySelector<HTMLElement>("[data-lightbox]");
  const lightboxImg = document.querySelector<HTMLImageElement>("[data-lightbox-img]");
  const closeBtn = document.querySelector("[data-lightbox-close]");

  document.querySelectorAll<HTMLElement>("[data-gallery-item]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const src = btn.dataset.src || "";
      if (lightbox && lightboxImg) {
        lightboxImg.src = src;
        lightbox.hidden = false;
        document.body.style.overflow = "hidden";
      }
    });
  });

  const close = () => {
    if (lightbox) {
      lightbox.hidden = true;
      document.body.style.overflow = "";
    }
  };

  closeBtn?.addEventListener("click", close);
  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) close();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") close();
  });
</script>