---
/**
 * SLIDER DE CAPÍTULOS — IEEE ICESI
 * Marquee infinito con los logos de los capítulos. Cada logo enlaza a su página.
 *
 * ─────────────────────────────────────────────────────────────
 * CÓMO AGREGAR / QUITAR UN CAPÍTULO:
 *   Este slider NO se edita aquí. Lee los datos desde:
 *       src/data/chapters.ts
 *
 *   Para agregar un capítulo:
 *   1. Pon su logo (SVG preferible) en:  src/assets/brand/logos/
 *   2. Abre  src/data/chapters.ts  y añade un objeto al array:
 *        {
 *          slug: "nuevo",                 // para la URL: /chapters/nuevo
 *          name: "NuevoCap",              // nombre corto
 *          fullName: "Nombre Completo",   // para SEO/accesibilidad
 *          logo: nuevoLogo,               // el import del logo
 *        }
 *   3. Importa el logo arriba en chapters.ts:
 *        import nuevoLogo from "../assets/brand/logos/nuevo.svg";
 *
 *   El capítulo aparece solo en el slider (y en cualquier lugar que use
 *   chapters.ts). Los logos oscuros se invierten a blanco en modo oscuro.
 * ─────────────────────────────────────────────────────────────
 *
 * By: Majumashe - WebMaster 2026
 */

import { chapters } from "../data/chapters";
---

<section class="chapters-section">
  <!-- Encabezado: kicker editorial (estándar del sitio) -->
  <div class="mx-auto mb-8 max-w-screen-xl px-6 lg:px-12">
    <div class="mb-4 border-l-[3px] border-ieee-blue pl-3">
      <span class="text-xs font-medium tracking-[1.5px] text-ieee-blue uppercase">
        Capítulos & Grupos
      </span>
    </div>
    <h2 class="chapters-title text-3xl font-bold tracking-tight lg:text-4xl">
      Nuestros capítulos técnicos
    </h2>
    <p class="chapters-sub mt-3 max-w-lg text-lg leading-relaxed">
      Seis sociedades técnicas donde puedes especializarte según tu interés.
    </p>
  </div>

  <!-- Marquee -->
  <div class="slider-container">
    <div class="slider-track">
      {
        chapters.map((chapter) => (
          <a href={`/chapters/${chapter.slug}`} class="slider-item" aria-label={chapter.fullName}>
            <img
              src={chapter.logo.src}
              alt={chapter.name}
              class="slider-logo"
              loading="lazy"
              decoding="async"
            />
          </a>
        ))
      }
      {/* Copia duplicada para el bucle infinito (oculta a lectores de pantalla) */}
      {
        chapters.map((chapter) => (
          <a
            href={`/chapters/${chapter.slug}`}
            class="slider-item"
            aria-hidden="true"
            tabindex={-1}
          >
            <img
              src={chapter.logo.src}
              alt=""
              class="slider-logo"
              loading="lazy"
              decoding="async"
            />
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* En modo oscuro, los logos oscuros se invierten a claro */
  :global([data-theme="dark"]) .slider-logo {
    filter: invert(1) brightness(1.8);
  }
  .chapters-section {
    background-color: var(--hero-bg);
    transition: background-color 0.3s ease;
    padding-top: 3rem;
  }
  .chapters-title {
    color: var(--hero-text);
  }
  .chapters-sub {
    color: var(--hero-text-muted);
  }

  .slider-container {
    overflow: hidden;
    padding: 2rem 0;
    /* Difuminado suave en los bordes laterales */
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }

  .slider-track {
    display: flex;
    width: max-content;
    animation: scroll 25s linear infinite;
  }
  .slider-container:hover .slider-track {
    animation-play-state: paused;
  }

  .slider-item {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 2rem;
    transition: transform 0.3s ease;
  }
  .slider-item:hover {
    transform: scale(1.08);
  }

  .slider-logo {
    height: 50px;
    width: auto;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }
  .slider-item:hover .slider-logo {
    opacity: 1;
  }

  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  /* Accesibilidad: sin movimiento si el usuario lo pide */
  @media (prefers-reduced-motion: reduce) {
    .slider-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
    }
    .slider-container {
      -webkit-mask-image: none;
      mask-image: none;
    }
  }
</style>
