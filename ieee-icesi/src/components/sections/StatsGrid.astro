---
/**
 * STATS GRID — IEEE ICESI ("Nuestra familia")
 * Estadísticas con conteo animado + tarjetas con acento de color.
 * UN SOLO componente que respeta el tema (claro/oscuro) vía variables --hero-*.
 * Fusiona las versiones clara y oscura en una.
 * By: Majumashe - WebMaster 2026
 */

const stats = [
  { to: 50, label: "Miembros activos", accent: "var(--color-ieee-blue)", icon: "users" },
  { to: 4, label: "Proyectos", accent: "var(--color-ieee-blue)", icon: "code" },
  { to: 25, label: "Eventos", accent: "var(--color-teal)", icon: "coffee" },
  { to: 65, label: "Voluntarios activos", accent: "var(--color-ieee-blue)", icon: "share" },
  { to: 11, label: "Comités y grupos", accent: "var(--color-teal)", icon: "groups" },
  { to: 1, label: "Premio", accent: "var(--color-warning)", icon: "trophy", float: true },
];

const icons: Record<string, string> = {
  users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  coffee: '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
  share: '<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>',
  groups: '<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>',
  trophy: '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>',
};
---

<section class="nf relative overflow-hidden px-6 py-20 lg:px-14" data-nf>
  <!-- Glow radial -->
  <div
    class="pointer-events-none absolute -top-44 left-1/2 h-[520px] w-[900px] -translate-x-1/2 rounded-full"
    style="background:radial-gradient(ellipse at center, color-mix(in srgb, var(--color-ieee-blue) 20%, transparent), transparent 60%)"
  >
  </div>
  <!-- Grilla decorativa -->
  <div class="nf-grid pointer-events-none absolute inset-0"></div>

  <header class="relative z-10 mx-auto mb-16 max-w-[1080px]">
    <!-- Kicker editorial: línea lateral + versalitas (estándar del sitio) -->
    <div class="mb-4 border-l-[3px] border-ieee-blue pl-3">
      <span
        class="text-xs font-medium tracking-[1.5px] text-ieee-blue uppercase"
      >
        La comunidad
      </span>
    </div>
    <h2 class="nf-title m-0 text-3xl font-bold tracking-tight lg:text-4xl">
      Nuestra familia
    </h2>
    <p class="nf-sub mt-3 max-w-lg text-lg leading-relaxed">
      Un vistazo rápido de lo que hemos construido juntos.
    </p>
  </header>

  <div
    class="relative z-10 mx-auto grid max-w-[1080px] grid-cols-1 gap-[22px] sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      stats.map((s, i) => (
        <article
          class="nf-card relative overflow-hidden rounded-[22px] border p-[34px_30px_30px]"
          style={`--accent:${s.accent}; animation-delay:${0.05 + i * 0.07}s`}
        >
          <span class="nf-line absolute inset-x-[30px] top-0 h-0.5 opacity-75" />
          <div
            class={`nf-icon mb-[22px] inline-flex h-[60px] w-[60px] items-center justify-center rounded-2xl${s.float ? " nf-float" : ""}`}
          >
            <svg
              width="30"
              height="30"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={icons[s.icon]}
            />
          </div>
          <div class="nf-num text-[54px] leading-none font-black tracking-[-0.03em]">
            <span data-count data-to={s.to}>
              0
            </span>
          </div>
          <div class="nf-label mt-2.5 text-[15px] font-semibold tracking-[0.04em]">
            {s.label}
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  /* Fondo y textos siguen el tema */
  .nf {
    background-color: var(--hero-bg);
    color: var(--hero-text);
    transition: background-color 0.3s ease;
  }
  .nf-title {
    color: var(--hero-text);
  }
  .nf-sub {
    color: var(--hero-text-muted);
  }
  .nf-num {
    color: var(--hero-text);
  }
  .nf-label {
    color: var(--hero-text-muted);
  }

  /* Grilla decorativa: la línea se adapta al texto del tema */
  .nf-grid {
    background-image:
      linear-gradient(
        color-mix(in srgb, var(--hero-text) 4%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--hero-text) 4%, transparent) 1px,
        transparent 1px
      );
    background-size: 54px 54px;
    background-position: center 200px;
    -webkit-mask-image: radial-gradient(
      ellipse 90% 60% at 50% 70%,
      #000 10%,
      transparent 95%
    );
    mask-image: radial-gradient(
      ellipse 90% 60% at 50% 70%,
      #000 10%,
      transparent 95%
    );
  }

  /* Tarjetas: fondo y borde derivan del acento + tema */
  .nf-card {
    opacity: 0;
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--accent) 10%, var(--hero-bg)),
      var(--hero-bg)
    );
    border-color: color-mix(in srgb, var(--hero-text) 10%, transparent);
    animation: nf-rise 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    transition:
      transform 0.35s cubic-bezier(0.2, 0.7, 0.2, 1),
      border-color 0.35s,
      box-shadow 0.35s;
  }
  .nf-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    box-shadow: 0 24px 50px -26px var(--accent);
  }

  .nf-line {
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
  }
  .nf-icon {
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    color: var(--accent);
  }
  .nf-float {
    animation: nf-float 3.4s ease-in-out infinite;
  }

  @keyframes nf-rise {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes nf-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  /* Respeta a quien pide menos movimiento */
  @media (prefers-reduced-motion: reduce) {
    .nf-card {
      opacity: 1;
      animation: none;
    }
    .nf-float {
      animation: none;
    }
    .nf-card:hover {
      transform: none;
    }
  }
</style>

<script>
  const root = document.querySelector("[data-nf]");
  if (root) {
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const els = [...root.querySelectorAll<HTMLElement>("[data-count]")];

    const run = (el: HTMLElement) => {
      const to = Number(el.dataset.to);
      if (reduceMotion) {
        el.textContent = String(to);
        return;
      }
      const dur = 1400;
      const start = performance.now();
      const tick = (now: number) => {
        const p = Math.min(1, (now - start) / dur);
        const e = 1 - Math.pow(1 - p, 3);
        el.textContent = String(Math.round(to * e));
        if (p < 1) requestAnimationFrame(tick);
        else el.textContent = String(to);
      };
      requestAnimationFrame(tick);
    };

    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (ents) => {
          ents.forEach((en) => {
            if (en.isIntersecting) {
              run(en.target as HTMLElement);
              io.unobserve(en.target);
            }
          });
        },
        { threshold: 0.4 },
      );
      els.forEach((el) => io.observe(el));
    } else {
      els.forEach(run);
    }
  }
</script>