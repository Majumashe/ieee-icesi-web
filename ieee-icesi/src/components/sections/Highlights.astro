---
/**
 * Sección: Experiencias IEEE ICESI
 * Inspirada en layout de 3 columnas con imagen + overlay
 * By: Majumashe - WebMaster 2026
 */

//Importar imágenes DESDE src/assets/images
import imgCV from "../../assets/images/cv.jpeg";
import imgFamilia from "../../assets/images/familia.jpeg";
import imgDiversion from "../../assets/images/diversion.jpeg";

const highlights = [
  {
    title: "Revisión de CV",
    description:
      "Te ayudamos a mejorar tu hoja de vida y prepararte para prácticas, convocatorias y oportunidades profesionales.",
    image: imgCV,
    icon: "resume",
  },
  {
    title: "FamiliIEEE",
    description:
      "Creamos espacios para integrarnos, conocer gente nueva y fortalecer la comunidad IEEE ICESI.",
    image: imgFamilia,
    icon: "community",
  },
  {
    title: "Recreación y Juegos",
    description:
      "Actividades recreativas y juegos para divertirnos, relajarnos y compartir fuera del aula.",
    image: imgDiversion,
    icon: "games",
  },
];
---
<section class="w-full">
  <div class="grid grid-cols-1 md:grid-cols-3">
    {highlights.map((item) => (
      <div class="relative h-80 lg:h-[420px] overflow-hidden">
        
        <!-- Imagen de fondo -->
        <img
          src={item.image.src}
          alt={item.title}
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />

        <!-- Overlay IEEE -->
        <div class="absolute inset-0 bg-ieee-blue/80"></div>

        <!-- Contenido -->
        <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6">
          
          <!-- Iconos simples (SVG inline recomendado luego) -->
          <div class="mb-5 text-white">
            {item.icon === "resume" && (
              <svg class="w-14 h-14 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M16 21H8a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v11a2 2 0 01-2 2z" />
                <path d="M14 3v4a2 2 0 002 2h4" />
              </svg>
            )}

            {item.icon === "community" && (
              <svg class="w-14 h-14 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 00-3-3.87" />
                <path d="M16 3.13a4 4 0 010 7.75" />
              </svg>
            )}

            {item.icon === "games" && (
              <svg class="w-14 h-14 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" />
                <path d="M8 12h8" />
                <path d="M12 8v8" />
              </svg>
            )}
          </div>

          <!-- Texto -->
          <h3 class="text-2xl font-semibold tracking-tight text-white mb-3">
            {item.title}
          </h3>
          <p class="text-white/90 text-base leading-relaxed max-w-xs">
            {item.description}
          </p>
        </div>
      </div>
    ))}
  </div>
</section>
