---
/**
 * Componente: Pasos para unirse
 * Estilo: inspirado en wireframe (oscuro, alto contraste, CTAs claros)
 * By: Majumashe - WebMaster 2026
 */

// Iconos de redes
import iconInstagram from "../../assets/icons/redes/instagram.svg";
import iconDiscord from "../../assets/icons/redes/discord.svg";

const steps = [
  {
    number: 1,
    title: "Síguenos",
    description:
      "Mantente al tanto de todo. Sigue nuestro Instagram y únete a nuestro Discord para enterarte de oportunidades, convocatorias, eventos y actividades exclusivas.",
    cta: null,
    socials: true,
  },
  {
    number: 2,
    title: "Asiste a Eventos",
    description:
      "Cada semana hacemos actividades sociales, técnicas y profesionales... ¡y casi siempre hay comida gratis! RSVP para no perderte cupos limitados.",
    cta: { label: "Ver próximos eventos", href: "/events" },
    socials: false,
  },
  {
    number: 3,
    title: "Hazte Miembro Oficial",
    description:
      "Llena el formulario de membresía y, si eliges pagar la cuota opcional de IEEE, podrás reclamar tu camiseta oficial y acceder a beneficios extra.",
    cta: { label: "Formulario de miembro", href: "#" },
    socials: false,
  },
];
---

<section class="py-16 bg-ieee-blue text-white">
  <div class="max-w-screen-xl mx-auto px-4 lg:px-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
      {steps.map((step) => (
        <div class="text-center flex flex-col items-center">
          <!-- Número (estilo wireframe) -->
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-white/90 text-title-black text-4xl font-semibold shadow-sm ring-1 ring-white/25 mb-6">
            {step.number}
          </div>

          <!-- Título -->
          <h3 class="text-2xl md:text-3xl font-semibold tracking-tight mb-4">
            {step.title}
          </h3>

          <!-- Descripción -->
          <p class="text-white/85 text-base leading-relaxed max-w-xs mb-8">
            {step.description}
          </p>

          <!-- Socials -->
          {step.socials && (
            <div class="flex justify-center gap-6 mt-auto">
              <a
                href="https://instagram.com/ieeeicesi"
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 flex items-center justify-center rounded-full border border-white/50 bg-white/0 hover:bg-white transition-colors duration-200"
                aria-label="Instagram"
              >
                <img
                  src={iconInstagram.src}
                  alt="Instagram"
                  class="w-6 h-6 invert group-hover:invert-0"
                />
              </a>
              <a
                href="https://discord.gg/ieeeicesi"
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 flex items-center justify-center rounded-full border border-white/50 bg-white/0 hover:bg-white transition-colors duration-200"
                aria-label="Discord"
              >
                <img
                  src={iconDiscord.src}
                  alt="Discord"
                  class="w-6 h-6 invert group-hover:invert-0"
                />
              </a>
            </div>
          )}

          <!-- CTA Button -->
          {step.cta && (
            <a
              href={step.cta.href}
              class="mt-auto inline-flex items-center justify-center px-7 py-3 rounded-xl border border-white/55 text-white
                     hover:bg-white hover:text-ieee-blue transition-colors duration-200 text-sm font-medium"
            >
              {step.cta.label}
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
