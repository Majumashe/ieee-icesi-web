---
/**
 * EVENTS SECTION — IEEE ICESI (inicio)
 * Próximos eventos (tarjetas ricas: fecha en bloque, organizadores, ponente,
 * modalidad, cupos, botón de inscripción) arriba.
 * Eventos pasados (tarjetas simples) abajo.
 * Datos de events.ts (clasificación automática por fecha).
 * By: Majumashe - WebMaster 2026
 */

import Button from "../ui/Button.astro";
import { getUpcomingEvents, getPastEvents } from "../../data/events";
import type { EventItem } from "../../data/events";
import { chapters } from "../../data/chapters";

const upcoming = getUpcomingEvents();
const past = getPastEvents().slice(0, 3);

// Busca un capítulo por su slug (para mostrar su logo como organizador)
function getChapter(slug: string) {
  return chapters.find((c) => c.slug === slug);
}

// Parte la fecha en día / mes / hora para el bloque destacado
function splitDate(iso: string) {
  const d = new Date(iso);
  return {
    day: d.toLocaleDateString("es-CO", { day: "2-digit" }),
    month: d.toLocaleDateString("es-CO", { month: "short" }).toUpperCase(),
    time: d.toLocaleTimeString("es-CO", {
      hour: "2-digit",
      minute: "2-digit",
    }),
  };
}

// Fecha simple (para pasados)
function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString("es-CO", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}
---

<section class="events-themed py-20">
  <div class="mx-auto max-w-screen-xl px-6 lg:px-12">
    <!-- Encabezado -->
    <div class="mb-12 flex flex-wrap items-end justify-between gap-4">
      <div>
        <div class="mb-4 border-l-[3px] border-ieee-blue pl-3">
          <span
            class="text-xs font-medium tracking-[1.5px] text-ieee-blue uppercase"
          >
            Eventos
          </span>
        </div>
        <h2 class="events-title text-3xl font-bold tracking-tight lg:text-4xl">
          Lo que está pasando
        </h2>
      </div>
      <Button href="/events" variant="outline">Ver todos los eventos</Button>
    </div>

    <!-- PRÓXIMOS (tarjetas ricas) -->
    {
      upcoming.length > 0 && (
        <div class="mb-16">
          <h3 class="events-subhead mb-6 text-sm font-bold tracking-[0.15em] uppercase">
            Próximos eventos
          </h3>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {upcoming.map((event: EventItem) => {
              const d = splitDate(event.date);
              return (
                <article class="event-card group">
                  {/* Imagen con fecha en bloque + logos organizadores */}
                  <div class="event-img">
                    <img src={event.image} alt={event.title} loading="lazy" decoding="async" />
                    {/* Bloque de fecha destacado */}
                    <div class="event-date-block">
                      <span class="event-date-day">{d.day}</span>
                      <span class="event-date-month">{d.month}</span>
                    </div>
                    {/* Logos de capítulos organizadores */}
                    {event.organizers && event.organizers.length > 0 && (
                      <div class="event-organizers">
                        {event.organizers.map((slug) => {
                          const ch = getChapter(slug);
                          return ch ? (
                            <img src={ch.logo.src} alt={ch.name} title={ch.fullName} />
                          ) : null;
                        })}
                      </div>
                    )}
                  </div>

                  <div class="event-body">
                    {/* Badges: tipo + modalidad */}
                    <div class="event-badges">
                      {event.type && <span class="badge badge-type">{event.type}</span>}
                      {event.modality && (
                        <span class="badge badge-modality">
                          <span class="badge-dot" />
                          {event.modality}
                        </span>
                      )}
                    </div>

                    <h4 class="event-name">{event.title}</h4>

                    <div class="event-meta">
                      <span class="event-metaitem">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <circle cx="12" cy="12" r="9" />
                          <polyline points="12 7 12 12 15 14" />
                        </svg>
                        {d.time}
                      </span>
                      <span class="event-metaitem">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z" />
                          <circle cx="12" cy="10" r="3" />
                        </svg>
                        {event.location}
                      </span>
                    </div>

                    {/* Ponente (si aplica) o mini-descripción (para SEO y llenar el espacio) */}
                    {event.speaker ? (
                      <div class="event-speaker">
                        {event.speaker.photo ? (
                          <img src={event.speaker.photo} alt={event.speaker.name} class="speaker-photo" />
                        ) : (
                          <span class="speaker-initials">
                            {event.speaker.name.split(" ").map((w) => w[0]).slice(0, 2).join("")}
                          </span>
                        )}
                        <div>
                          <div class="speaker-name">{event.speaker.name}</div>
                          <div class="speaker-role">{event.speaker.role}</div>
                        </div>
                      </div>
                    ) : (
                      <p class="event-desc">{event.description}</p>
                    )}

                    {/* Empuja cupos + botón al fondo para alinear todas las tarjetas */}
                    <div class="event-footer">
                      {event.capacity && (
                        <div class="event-capacity">{event.capacity} cupos disponibles</div>
                      )}
                      {event.registerUrl && (
                        <a href={event.registerUrl} class="event-register" target="_blank" rel="noopener">
                          Inscribirme
                        </a>
                      )}
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      )
    }

    <!-- PASADOS (tarjetas simples) -->
    {
      past.length > 0 && (
        <div>
          <h3 class="events-subhead mb-6 text-sm font-bold tracking-[0.15em] uppercase">
            Eventos pasados
          </h3>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {past.map((event: EventItem) => (
              <a href={`/events/${event.slug}`} class="past-card group">
                <div class="past-img">
                  <img src={event.image} alt={event.title} loading="lazy" decoding="async" />
                  <span class="badge badge-past">Realizado</span>
                </div>
                <div class="past-body">
                  <div class="past-date">{formatDate(event.date)}</div>
                  <h4 class="past-name">{event.title}</h4>
                  <p class="past-loc">{event.location}</p>
                  {event.rating && (
                    <div class="past-rating" aria-label={`Calificación ${event.rating} de 5`}>
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                      </svg>
                      <span>{event.rating.toFixed(1)}</span>
                    </div>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .events-themed {
    background-color: var(--hero-bg);
    transition: background-color 0.3s ease;
  }
  .events-title {
    color: var(--hero-text);
  }
  .events-subhead {
    color: var(--hero-text-muted);
  }

  /* ===== Tarjeta de próximo evento (rica) ===== */
  .event-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 18px;
    background-color: color-mix(in srgb, var(--hero-text) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--hero-text) 10%, transparent);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }
  .event-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--color-ieee-blue) 50%, transparent);
    box-shadow: 0 22px 44px -26px rgba(0, 0, 0, 0.5);
  }

  .event-img {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-ieee-blue) 12%, var(--hero-bg));
  }
  .event-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Bloque de fecha destacado (esquina) */
  .event-date-block {
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    background: var(--color-gunmetal);
    color: white;
    border-bottom-right-radius: 14px;
  }
  .event-date-day {
    font-size: 24px;
    font-weight: 800;
    line-height: 1;
  }
  .event-date-month {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  /* Logos de organizadores (esquina opuesta) */
  .event-organizers {
    position: absolute;
    top: 10px;
    right: 10px;
    display: flex;
    gap: 6px;
    padding: 5px 8px;
    background: rgba(255, 255, 255, 0.92);
    border-radius: 8px;
  }
  .event-organizers img {
    height: 22px;
    width: auto;
  }

  .event-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 18px;
    flex: 1; /* crece para llenar la tarjeta y alinear los footers */
  }

  .event-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 600;
  }
  .badge-type {
    background: var(--color-ieee-blue);
    color: white;
  }
  .badge-modality {
    background: color-mix(in srgb, var(--hero-text) 8%, transparent);
    color: var(--hero-text-muted);
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-teal);
  }

  .event-name {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.25;
    color: var(--hero-text);
  }

  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 13px;
    color: var(--hero-text-muted);
  }
  .event-metaitem {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .event-metaitem svg {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    color: var(--color-ieee-blue);
  }

  /* Footer: cupos + botón, empujado al fondo de la tarjeta */
  .event-footer {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 4px;
  }

  /* Ponente */
  .event-speaker {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    border-top: 1px solid color-mix(in srgb, var(--hero-text) 8%, transparent);
  }
  .speaker-photo,
  .speaker-initials {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .speaker-initials {
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-ieee-blue) 15%, transparent);
    color: var(--color-ieee-blue);
    font-size: 13px;
    font-weight: 700;
  }
  .speaker-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--hero-text);
  }
  .speaker-role {
    font-size: 12px;
    color: var(--hero-text-muted);
  }

  /* Mini-descripción (cuando no hay ponente) */
  .event-desc {
    font-size: 13px;
    line-height: 1.5;
    color: var(--hero-text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .event-capacity {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-teal);
  }

  .event-register {
    margin-top: 4px;
    display: block;
    padding: 11px;
    border-radius: 10px;
    background: var(--color-ieee-blue);
    color: white;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }
  .event-register:hover {
    background: var(--color-icesi-blue);
    transform: translateY(-1px);
  }

  /* ===== Tarjeta de evento pasado (simple) ===== */
  .past-card {
    display: block;
    overflow: hidden;
    border-radius: 14px;
    background-color: color-mix(in srgb, var(--hero-text) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--hero-text) 10%, transparent);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  .past-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 32px -24px rgba(0, 0, 0, 0.5);
  }
  .past-img {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .past-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.4);
  }
  .badge-past {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--color-slate-blue);
    color: white;
  }
  .past-body {
    padding: 14px 16px;
  }
  .past-date {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-ieee-blue);
    text-transform: capitalize;
  }
  .past-name {
    margin: 5px 0 3px;
    font-size: 15px;
    font-weight: 600;
    color: var(--hero-text);
  }
  .past-loc {
    font-size: 13px;
    color: var(--hero-text-muted);
  }
  .past-rating {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--hero-text);
  }
  .past-rating svg {
    width: 15px;
    height: 15px;
    color: #f4b400; /* warning/amarillo para la estrella */
  }

  @media (prefers-reduced-motion: reduce) {
    .event-card:hover,
    .past-card:hover,
    .event-register:hover {
      transform: none;
    }
  }
</style>