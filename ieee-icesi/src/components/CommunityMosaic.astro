---
/**
 * COMMUNITY MOSAIC — IEEE ICESI
 * Mosaico de fotos de la comunidad estilo POLAROID que flotan suavemente,
 * con texto central + CTA. Cada foto crece al pasar el mouse sobre ella.
 * Redirige a la pestaña de comunidad.
 *
 * ─────────────────────────────────────────────────────────────
 * CÓMO AGREGAR FOTOS:
 *   Suelta las imágenes en:  src/assets/community/
 *   (formatos: .jpg .jpeg .png .webp)
 *   El mosaico tiene 10 posiciones. Se llenan por orden alfabético
 *   de nombre de archivo. Nómbralas 01-xxx.jpg, 02-xxx.jpg, etc.
 *   para controlar el orden. Más de 10 → las extra no se muestran.
 * ─────────────────────────────────────────────────────────────
 *
 * By: Majumashe - WebMaster 2026
 */

import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Button from "./ui/Button.astro";

// Carga automática de las fotos de la comunidad
const modules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/community/*.{jpg,jpeg,png,webp}",
  { eager: true },
);

const photos = Object.entries(modules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);

// 10 posiciones del mosaico. Cada una: ubicación, ancho, rotación (rot),
// y retraso de la animación (delay) para que no floten todas a la vez.
const positions = [
  { style: "top:4%; left:1%;", w: 185, rot: -4, delay: "0s" },
  { style: "top:9%; left:16%;", w: 160, rot: 3, delay: "0.8s" },
  { style: "top:2%; left:31%;", w: 150, rot: -2, delay: "1.4s" },
  { style: "top:3%; right:29%;", w: 172, rot: 2, delay: "0.5s" },
  { style: "top:7%; right:15%;", w: 155, rot: 5, delay: "1.1s" },
  { style: "top:4%; right:0%;", w: 185, rot: -3, delay: "0.3s" },
  { style: "bottom:5%; left:4%;", w: 175, rot: 4, delay: "1.6s" },
  { style: "bottom:9%; left:22%;", w: 152, rot: -3, delay: "0.2s" },
  { style: "bottom:6%; right:20%;", w: 178, rot: 2, delay: "1.3s" },
  { style: "bottom:4%; right:2%;", w: 168, rot: -5, delay: "0.7s" },
];

const tiles = photos.slice(0, positions.length).map((photo, i) => ({
  photo,
  ...positions[i],
}));
---

<section class="community-section">
  <!-- Mosaico de polaroids (oculto en móvil) -->
  <div class="community-mosaic" aria-hidden="true">
    {
      tiles.map((tile) => (
        <div
          class="polaroid"
          style={`${tile.style} width:${tile.w}px; --rot:${tile.rot}deg; --delay:${tile.delay};`}
        >
          <Image
            src={tile.photo}
            alt=""
            width={tile.w * 2}
            loading="lazy"
            decoding="async"
          />
        </div>
      ))
    }
  </div>

  <!-- Texto central -->
  <div class="community-content">
    <div class="community-kicker">Nuestra comunidad</div>
    <h2 class="community-title">La familia IEEE ICESI</h2>
    <p class="community-sub">
      Estudiantes, líderes y soñadores construyendo el futuro de la ingeniería.
    </p>
    <div class="mt-6">
      <Button href="/community" variant="hero">Conoce a la comunidad</Button>
    </div>
  </div>
</section>

<style>
  .community-section {
    position: relative;
    overflow: hidden;
    background-color: var(--hero-bg);
    transition: background-color 0.3s ease;
    padding: 5rem 1.5rem;
    min-height: 560px;
  }

  /* Glow radial central: halo azul suave detrás del texto */
  .community-section::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 800px;
    height: 500px;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--color-ieee-blue) 14%, transparent),
      transparent 65%
    );
    pointer-events: none;
    z-index: 0;
  }

  .community-mosaic {
    position: absolute;
    inset: 0;
    display: none;
  }
  @media (min-width: 1024px) {
    .community-mosaic {
      display: block;
    }
  }

  /* Estilo polaroid: marco blanco (más grueso abajo) + rotación + flotación */
  .polaroid {
    position: absolute;
    aspect-ratio: 1 / 1;
    background: #fff;
    padding: 8px 8px 26px;
    border-radius: 4px;
    box-shadow: 0 14px 30px -12px rgba(0, 0, 0, 0.45);
    transform: rotate(var(--rot));
    animation: float 5s ease-in-out infinite;
    animation-delay: var(--delay);
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease;
    will-change: transform;
  }
  .polaroid img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 2px;
  }

  /* Al pasar el mouse: se endereza, crece y sube al frente */
  .polaroid:hover {
    transform: rotate(0deg) scale(1.08);
    box-shadow: 0 24px 48px -16px rgba(0, 0, 0, 0.6);
    z-index: 20;
    animation-play-state: paused;
  }

  /* Flotación suave: sube y baja manteniendo su rotación */
  @keyframes float {
    0%,
    100% {
      transform: rotate(var(--rot)) translateY(0);
    }
    50% {
      transform: rotate(var(--rot)) translateY(-12px);
    }
  }

  .community-content {
    position: relative;
    z-index: 10;
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    padding: 5rem 0;
  }
  .community-kicker {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-ieee-blue);
    margin-bottom: 12px;
  }
  .community-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--hero-text);
    margin-bottom: 14px;
  }
  .community-sub {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--hero-text-muted);
  }

  /* Sin flotación si el usuario pide menos movimiento (conserva rotación estática) */
  @media (prefers-reduced-motion: reduce) {
    .polaroid {
      animation: none;
    }
    .polaroid:hover {
      transform: rotate(0deg) scale(1.05);
    }
  }
</style>