---
/**
 * Dependencias: Tailwind CSS v4 and use please kebab-case for ids and camelCase for const and var:D
 * Congrats for your new charge!:3
 * By: Majumashe - WebMaster 2026
 */
const nameBranch = "Rama estudiantil IEEE de la Universidad Icesi";
import bgMint from "../assets/hero/bgMint.svg";
import IconCollage from "./IconCollage.astro";
import Button from "./ui/Button.astro";
---

<main>
  <section
    class="hero-themed relative mx-auto grid max-w-screen-xl grid-cols-1 items-center gap-8 px-0 py-8 text-left lg:grid-cols-2 lg:px-12 lg:py-16"
  >
    <!-- Columna 1: contenido -->
    <div class="relative z-10 px-8 lg:px-0">
      <!-- Fondo menta (solo móvil, decorativo) -->
      <img
        src={bgMint.src}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 -z-10 h-full w-full object-cover lg:hidden"
      />

      <!-- Kicker editorial: línea lateral + versalitas -->
      <div class="mb-5 border-l-[3px] border-ieee-blue pl-3">
        <span
          class="text-xs font-medium tracking-[1.5px] text-ieee-blue uppercase"
        >
          IEEE · Universidad ICESI
        </span>
      </div>

      <h1
        class="hero-title mb-4 text-4xl leading-tight font-bold lg:text-5xl"
      >
        Conecta tu talento con el mundo de la ingeniería.
      </h1>

      <p class="hero-lead">
        Somos la {nameBranch}. Creamos espacios donde la tecnología, el
        liderazgo y la innovación se convierten en
        <span class="hero-emph font-semibold">
          experiencia real, comunidad y proyección profesional.
        </span>
      </p>

      <!-- CTAs: en fila desde sm, apilados en móvil estrecho -->
      <div class="flex flex-col gap-4 py-6 sm:flex-row">
        <Button href="/join-us" variant="hero">Ser miembro</Button>
        <Button href="/sponsor" variant="outline">Ser patrocinador</Button>
      </div>
    </div>

    <!-- Columna 2: collage (oculto en móvil) -->
    <div class="hidden justify-center lg:flex lg:justify-end">
      <IconCollage class="max-w-sm" />
    </div>
  </section>
</main>

<style>
  .hero-themed {
    background-color: var(--hero-bg);
    transition: background-color 0.3s ease;
  }
  .hero-title {
    color: var(--hero-text);
  }
  .hero-lead {
    color: var(--hero-text-muted);
  }
  .hero-emph {
    color: var(--hero-text);
  }
</style>