---
/**
 * PÁGINA INDIVIDUAL DE EVENTO — /events/[slug]
 * Genera una página por cada evento del events.ts (rutas dinámicas).
 * Guardar como: src/pages/events/[slug].astro
 * By: Majumashe - WebMaster 2026
 */
import EventActions from "../../components/EventActions.astro";
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/ui/Button.astro";
import { events } from "../../data/events";
import { chapters } from "../../data/chapters";
import EventGallery from "../../components/EventGallery.astro";

// getStaticPaths: le dice a Astro qué páginas generar (una por evento).
export function getStaticPaths() {
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;

const isPast = new Date(event.date) < new Date();

const dateStr = new Date(event.date).toLocaleDateString("es-CO", {
  weekday: "long",
  day: "numeric",
  month: "long",
  year: "numeric",
});
const timeStr = new Date(event.date).toLocaleTimeString("es-CO", {
  hour: "2-digit",
  minute: "2-digit",
});

const organizerChapters = (event.organizers || [])
  .map((slug) => chapters.find((c) => c.slug === slug))
  .filter(Boolean);
---

<Layout title={event.title} description={event.description}>
  <article class="event-detail">
    <!-- Imagen grande -->
    <div class="event-hero-img">
      <img src={event.image} alt={event.title} />
      <div class="event-hero-overlay"></div>
    </div>

    <div class="mx-auto max-w-4xl px-6 py-12 lg:px-12">
      <!-- Volver -->
      <a href="/events" class="back-link">← Volver a eventos</a>

      <!-- Badges -->
      <div class="detail-badges">
        {event.type && <span class="badge badge-type">{event.type}</span>}
        {event.modality && <span class="badge badge-modality">{event.modality}</span>}
        {isPast && <span class="badge badge-past-inline">Evento realizado</span>}
      </div>

      <h1 class="detail-title">{event.title}</h1>

      <!-- Meta principal -->
      <div class="detail-meta">
        <div class="detail-meta-item">
          <strong>Fecha</strong>
          <span class="capitalize">{dateStr}</span>
        </div>
        <div class="detail-meta-item">
          <strong>Hora</strong>
          <span>{timeStr}</span>
        </div>
        <div class="detail-meta-item">
          <strong>Lugar</strong>
          <span>{event.location}</span>
        </div>
        {
          event.capacity && (
            <div class="detail-meta-item">
              <strong>Cupos</strong>
              <span>{event.capacity} disponibles</span>
            </div>
          )
        }
      </div>

      <!-- Descripción -->
      <p class="detail-desc">{event.description}</p>

      <EventActions event={event} />

      <!-- Ponente -->
      {
        event.speaker && (
          <div class="detail-speaker">
            {event.speaker.photo ? (
              <img src={event.speaker.photo} alt={event.speaker.name} />
            ) : (
              <span class="detail-speaker-initials">
                {event.speaker.name
                  .split(" ")
                  .map((w) => w[0])
                  .slice(0, 2)
                  .join("")}
              </span>
            )}
            <div>
              <div class="detail-speaker-label">Ponente</div>
              <div class="detail-speaker-name">{event.speaker.name}</div>
              <div class="detail-speaker-role">{event.speaker.role}</div>
            </div>
          </div>
        )
      }

      <!-- Organizadores -->
      {
        organizerChapters.length > 0 && (
          <div class="detail-organizers">
            <span class="detail-organizers-label">Organizado por</span>
            <div class="detail-organizers-logos">
              {organizerChapters.map((ch) => (
                <a href={`/chapters/${ch!.slug}`} title={ch!.fullName}>
                  <img src={ch!.logo.src} alt={ch!.name} />
                </a>
              ))}
            </div>
          </div>
        )
      }

      <!-- CTA de inscripción (solo próximos) -->
      {
        !isPast && event.registerUrl && (
          <div class="detail-cta">
            <Button href={event.registerUrl} variant="hero">
              Inscribirme a este evento
            </Button>
          </div>
        )
      }

      <!-- Calificación (solo pasados) -->
      {
        isPast && event.rating && (
          <div class="detail-rating">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
            <span>{event.rating.toFixed(1)} / 5 según asistentes</span>
          </div>
        )
      } 
      <EventGallery slug={event.slug} title={event.title} />
    </div>
   
  </article>
</Layout>

<style>
  :global([data-theme="dark"]) .detail-organizers-logos img {
    filter: brightness(0) invert(1);
  }
  .event-detail {
    background-color: var(--hero-bg);
    transition: background-color 0.3s ease;
  }

  .event-hero-img {
    position: relative;
    height: 320px;
    overflow: hidden;
  }
  .event-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .event-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--hero-bg), transparent 60%);
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ieee-blue);
  }
  .back-link:hover {
    text-decoration: underline;
  }

  .detail-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 1rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
  }
  .badge-type {
    background: var(--color-ieee-blue);
    color: white;
  }
  .badge-modality {
    background: color-mix(in srgb, var(--hero-text) 8%, transparent);
    color: var(--hero-text-muted);
  }
  .badge-past-inline {
    background: var(--color-slate-blue);
    color: white;
  }

  .detail-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--hero-text);
    margin-bottom: 1.5rem;
  }

  .detail-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
    padding: 20px 0;
    border-top: 1px solid color-mix(in srgb, var(--hero-text) 10%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--hero-text) 10%, transparent);
    margin-bottom: 2rem;
  }
  .detail-meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .detail-meta-item strong {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ieee-blue);
  }
  .detail-meta-item span {
    font-size: 15px;
    color: var(--hero-text);
  }

  .detail-desc {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--hero-text-muted);
    margin-bottom: 2rem;
  }

  .detail-speaker {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--hero-text) 4%, transparent);
    margin-bottom: 2rem;
  }
  .detail-speaker img,
  .detail-speaker-initials {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .detail-speaker-initials {
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-ieee-blue) 15%, transparent);
    color: var(--color-ieee-blue);
    font-size: 20px;
    font-weight: 700;
  }
  .detail-speaker-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ieee-blue);
  }
  .detail-speaker-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--hero-text);
  }
  .detail-speaker-role {
    font-size: 14px;
    color: var(--hero-text-muted);
  }

  .detail-organizers {
    margin-bottom: 2rem;
  }
  .detail-organizers-label {
    display: block;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ieee-blue);
    margin-bottom: 10px;
  }
  .detail-organizers-logos {
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .detail-organizers-logos img {
    height: 40px;
    width: auto;
  }

  .detail-cta {
    margin-top: 1rem;
  }

  .detail-rating {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;
    font-weight: 600;
    color: var(--hero-text);
  }
  .detail-rating svg {
    width: 22px;
    height: 22px;
    color: #f4b400;
  }
</style>
